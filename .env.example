# ── Supabase (get from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Server-only (never expose to frontend) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── API key encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
API_KEY_ENCRYPTION_SECRET=your-64-char-hex-string

# ── Deployment (set these when deploying) ──
# VITE_API_URL=https://your-backend.onrender.com    (frontend env — points to backend)
# FRONTEND_URL=https://your-app.vercel.app           (backend env — for CORS)

# ── Server port ──
PORT=3001
